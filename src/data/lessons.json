  {
    "id": "lesson-7",
    "grammarPoint": "〜がする",
    "category": "sensory",
    "title": "Sensory Perception with がする",
    "explanation": "〜がする expresses perception of sounds, smells, tastes, and feelings. The subject is the sensory stimulus, and する here means 'to be perceived'. Common: 音がする (sounds), においがする (smells), 味がする (tastes), 気がする (feels).",
    "exercises": [
      {
        "id": "ex-7-1",
        "prompt": "Something smells good.",
