          { "id": "t-7-1-1", "text": "いいにおい", "type": "noun" },
          { "id": "t-7-1-2", "text": "が", "type": "particle" },
          { "id": "t-7-1-3", "text": "する", "type": "verb" },
          { "id": "t-7-1-4", "text": "は", "type": "particle" }
        ],
